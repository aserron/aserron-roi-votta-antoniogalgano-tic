---
layout: layouts/base.njk
pageTitle: "Glosario Startups TIC Uruguay — Términos del Ecosistema Emprendedor | Antonio Galgano Votta"
metaDescription: "Glosario completo de términos clave del ecosistema emprendedor TIC en Uruguay: financiamiento, marco legal, infraestructura, talento y operación."
canonical: "https://antoniogalgano-tic.com/glossary"
ogTitle: "Glosario Startups TIC Uruguay — Antonio Galgano Votta"
ogDescription: "Aprende sobre el ecosistema emprendedor de Uruguay: ANDE, ANNI, SAS, financiamiento, infraestructura y talento TIC."
ogUrl: "https://antoniogalgano-tic.com/glossary"
permalink: /glossary/index.html
---

{% set groupedTerms = collections.glossary | groupByCategory %}

{% block schemaTags %}
<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "DefinedTermSet",
        "name": "Glosario Startups TIC Uruguay",
        "description": "Glosario del ecosistema emprendedor tecnológico de Uruguay: términos sobre financiamiento, marco legal, infraestructura, talento y operación de startups.",
        "url": "https://antoniogalgano-tic.com/glossary",
        "hasPart": [
            {% for term in collections.glossary -%}
            {
                "@type": "DefinedTerm",
                "name": "{{ term.data.term }}",
                "url": "https://antoniogalgano-tic.com/glossary/{{ term.data.slug }}",
                "description": "{{ term.data.metaDescription | replace('\"', '') }}"
            }{{ "," if not loop.last }}
            {%- endfor %}
        ]
    }
</script>
{% endblock %}

<main class="glossary-page">
    <div class="glossary-container">
        <header style="padding: 4rem 2rem 2rem; border-bottom: 1px solid var(--border); margin-bottom: 2rem;">
          <div class="section-eyebrow">Ecosistema TIC Uruguay</div>
          <h1 class="glossary-title">Glosario Startups</h1>
          <p class="glossary-description">
            Términos clave del ecosistema emprendedor tecnológico de Uruguay: financiamiento, marco legal, infraestructura,
            talento y estrategia operacional — explicados para emprendedores y fundadores.
          </p>
        </header>

        <div class="glossary-search">
            <input type="text" id="glossary-search" placeholder="Buscar término..." aria-label="Buscar en el glosario">
        </div>

        <div class="glossary-content">
            {% for category, terms in groupedTerms | dictsort %}
            <section class="glossary-section" data-category="{{ terms[0].data.categorySlug }}">
                <h2 class="category-title">{{ category }}</h2>
                <div class="glossary-items">
                    {% for term in terms %}
                    <article class="glossary-item" data-term="{{ term.data.slug }}" data-category="{{ term.data.category }}">
                        <h3 class="term-heading">
                            <a href="/glossary/{{ term.data.slug }}">{{ term.data.term }}</a>
                        </h3>
                        <p class="term-definition">
                            {{ term.templateContent | safe }}
                        </p>
                    </article>
                    {% endfor %}
                </div>
            </section>
            {% endfor %}
        </div>

        <section style="padding: 4rem 2rem; border-top: 1px solid var(--border); text-align: center; margin-top: 4rem;">
          <h2 style="font-size: 2rem; font-family: 'IBM Plex Mono', monospace; color: var(--text-bright); margin-bottom: 1rem;">
            ¿Planeas tu startup en Uruguay?
          </h2>
          <p style="font-size: 1.125rem; color: var(--text); max-width: 40rem; margin: 0 auto 2rem; line-height: 1.7;">
            Disponible para asesoría especializada en TIC, estrategia de startup, y navegación del ecosistema uruguayo.
          </p>
          <a href="https://www.linkedin.com/in/antonio-galgano-votta-713b523a7/"
             target="_blank" rel="noopener noreferrer" class="btn-solid">
            Solicitar Asesoría
          </a>
        </section>
    </div>
</main>

<script>
    const searchInput = document.getElementById('glossary-search');
    const glossaryItems = document.querySelectorAll('.glossary-item');

    searchInput.addEventListener('input', function() {
        const searchTerm = this.value.toLowerCase();

        glossaryItems.forEach(item => {
            const itemText = item.textContent.toLowerCase();
            if (itemText.includes(searchTerm)) {
                item.style.display = 'block';
            } else {
                item.style.display = 'none';
            }
        });
    });
</script>
