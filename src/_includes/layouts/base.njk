<!DOCTYPE html>
<html lang="{{ site.lang }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- PRIMARY SEO -->
    <title>{% block pageTitle %}Antonio Galgano Votta | Consultor IT y Ciberseguridad{% endblock %}</title>
    <meta name="description"
          content="{% block metaDescription %}Antonio Galgano Votta — Consultor especializado en tecnologías de la información y ciberseguridad. Experto en infraestructura digital segura.{% endblock %}">
    <meta name="author" content="{{ site.name }}">
    {% if robots %}<meta name="robots" content="{{ robots }}">{% else %}<meta name="robots" content="index, follow">{% endif %}
    <link rel="canonical" href="{% block canonical %}{{ site.baseUrl }}/{% endblock %}">
    <link rel="alternate" hreflang="{{ site.lang }}" href="{% block hreflang %}{{ site.baseUrl }}/{% endblock %}">
    <link rel="alternate" hreflang="x-default" href="{{ site.baseUrl }}/">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="{{ site.themeColor }}">

    <!-- SECURITY & INFRASTRUCTURE SIGNALS -->
    <link rel="security.txt" href="/.well-known/security.txt">
    <link rel="author" href="/humans.txt">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="referrer" content="strict-origin-when-cross-origin">
    <meta http-equiv="Permissions-Policy" content="geolocation=(), microphone=(), camera=()">

    <!-- FAVICONS -->
    <link rel="icon" type="image/x-icon" href="/images/favico/favicon_io/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favico/favicon_io/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favico/favicon_io/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/images/favico/favicon_io/favicon-192x192.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/images/favico/favicon_io/apple-touch-icon.png">

    <!-- OPEN GRAPH -->
    <meta property="og:title" content="{% block ogTitle %}Antonio Galgano Votta | Consultor IT y Ciberseguridad{% endblock %}">
    <meta property="og:description"
          content="{% block ogDescription %}Especialista en infraestructura digital segura, automatización y ciberseguridad empresarial.{% endblock %}">
    <meta property="og:url" content="{% block ogUrl %}{{ site.baseUrl }}/{% endblock %}">
    <meta property="og:type" content="{% block ogType %}website{% endblock %}">
    <meta property="og:locale" content="{{ site.locale }}">
    <meta property="og:site_name" content="{{ site.name }}">
    <meta property="og:image" content="{{ site.ogImage }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="Antonio Galgano Votta — Consultor IT y Ciberseguridad">

    <!-- TWITTER CARD -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="{{ site.twitter }}">
    <meta name="twitter:creator" content="{{ site.twitter }}">
    <meta name="twitter:title" content="{% block twitterTitle %}Antonio Galgano Votta | Consultor IT y Ciberseguridad{% endblock %}">
    <meta name="twitter:description"
          content="{% block twitterDescription %}Especialista en infraestructura digital segura y ciberseguridad empresarial.{% endblock %}">
    <meta name="twitter:image" content="{{ site.ogImage }}">
    <meta name="twitter:image:alt" content="Antonio Galgano Votta — Consultor IT y Ciberseguridad">

    <!-- SCHEMA.ORG TAGS -->
    {% block schemaTags %}{% endblock %}

    <!-- CRITICAL CSS: Above-the-fold styles (inline for instant rendering) -->
    {% block criticalCss %}{% endblock %}

    <!-- Tailwind CSS stylesheet (non-blocking async load for below-the-fold) -->
    <link rel="preload" href="/css/styles.css" as="style">
    <link rel="stylesheet" href="/css/styles.css" media="print" onload="this.media='all'">
    <noscript>
        <link rel="stylesheet" href="/css/styles.css">
    </noscript>
</head>
<body>
{% include "partials/header.njk" %}
{% block content %}{{ content | safe }}{% endblock %}
{% include "partials/footer.njk" %}
<script>
  const _obs = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('visible'); _obs.unobserve(e.target); }
    }),
    { threshold: 0.08 }
  );
  document.querySelectorAll('.reveal').forEach((el) => _obs.observe(el));
</script>
</body>
</html>
