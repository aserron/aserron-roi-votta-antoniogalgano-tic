{% block criticalCss %}
<style>
    :root {
        --bg: #07080f;
        --bg-raised: #0c0e1c;
        --cyan: #00d8ff;
        --emerald: #34d399;
        --text: #8ea3be;
        --text-mid: #c1cfe0;
        --text-bright: #e8f0fe;
        --accent: #ff6b35;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        margin: 0;
        padding: 0;
        font-family: 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background-color: var(--bg);
        color: var(--text);
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    .hero {
        position: relative;
        display: flex;
        min-height: 100vh;
        align-items: center;
        justify-content: center;
        padding: 3rem 2rem;
        background: linear-gradient(135deg, var(--bg) 0, var(--bg-raised) 100%);
        overflow: hidden;
    }

    .hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -50%;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle, rgba(52, 211, 153, 0.05) 0, transparent 70%);
        animation: float 20s ease-in-out infinite;
    }

    .hero-inner {
        position: relative;
        z-index: 10;
        max-width: 48rem;
        text-align: center;
    }

    .hero-content {
        animation: fadeInUp 1s ease-out 0.2s both;
    }

    .hero-title {
        font-size: clamp(2.5rem, 8vw, 4rem);
        font-weight: 700;
        margin-bottom: 0.5rem;
        line-height: 1.25;
        letter-spacing: -0.025em;
    }

    .hero-name {
        background: linear-gradient(135deg, var(--cyan) 0, var(--emerald) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-subtitle {
        font-size: clamp(1rem, 3vw, 1.5rem);
        font-weight: 500;
        color: var(--text-mid);
        margin-bottom: 1.5rem;
    }

    .hero-status {
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--accent);
        margin-bottom: 1.5rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .hero-description {
        font-size: 1.125rem;
        color: var(--text);
        max-width: 42rem;
        margin: 0 auto 2rem;
        line-height: 1.8;
    }

    @keyframes float {
        0%, 100% {
            transform: translate(0, 0);
        }
        50% {
            transform: translate(30px, -30px);
        }
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .hero-inner-2col {
        position: relative;
        z-index: 10;
        max-width: 72rem;
        margin: 0 auto;
        width: 100%;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }
    .hero-name-block {
        font-family: 'IBM Plex Mono', monospace;
        font-weight: 700;
        font-size: clamp(2.5rem, 5vw, 3.5rem);
        line-height: 1.1;
        color: var(--text-bright);
        margin-bottom: 1.5rem;
    }
    .hero-name-block span { display: block; }
    .hero-flag {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.75rem;
        color: var(--text);
    }
    .hero-flag .sep { color: var(--border-cyan); }
    .hero-flag .loc { color: var(--cyan); }
    .hero-role {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 1.125rem;
        margin-bottom: 1rem;
        color: var(--text-mid);
    }
    .hero-role .prompt { color: var(--cyan); }
    .btn-solid {
        display: inline-block;
        padding: 0.75rem 1.5rem;
        border-radius: 0.25rem;
        font-weight: 600;
        font-size: 0.875rem;
        text-decoration: none;
        background: var(--cyan);
        color: var(--bg);
    }
    .btn-ghost {
        display: inline-block;
        padding: 0.75rem 1.5rem;
        border-radius: 0.25rem;
        font-weight: 600;
        font-size: 0.875rem;
        text-decoration: none;
        border: 1px solid var(--cyan);
        color: var(--cyan);
    }
    .hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2rem; }
    @media (max-width: 900px) {
        .hero-inner-2col { grid-template-columns: 1fr; }
        .hero-vis { display: none; }
    }
</style>
{% endblock %}

{% block schemaTags %}
