{% block content %}
<main>

<!-- ═══ HERO ══════════════════════════════════════════════════════════ -->
<section class="hero">
  <div class="hero-grid"></div>
  <div class="hero-glow-r"></div>
  <div class="hero-glow-l"></div>

  <div class="hero-inner-2col">
    <div class="reveal">
      <div class="hero-flag">
        <span>// TIC URUGUAY / STARTUPS</span>
        <span class="sep">/</span>
        <span class="loc">ECOSISTEMA EMPRENDEDOR</span>
      </div>

      <h1 class="hero-name-block" fetchpriority="high">
        <span>Antonio</span>
        <span>Galgano</span>
        <span>Votta</span>
      </h1>

      <div class="hero-role">
        <span class="prompt">&gt;</span>
        Consultor TIC &amp; Ecosistema Emprendedor
      </div>

      <p class="hero-description">
        ¿Por qué crear tu próxima startup en Uruguay? Ecosistema robusto, financiamiento accesible,
        marco legal innovador y talento tecnológico de clase mundial.
      </p>

      <div class="hero-btns">
        <a href="/glossary" class="btn-solid">Explorar Ecosistema</a>
        <a href="#contacto" class="btn-ghost">Solicitar Asesoría</a>
      </div>

      <div class="hero-stats">
        <div class="reveal reveal-delay-1">
          <div class="stat-val">10<span style="font-size:1.25rem">+</span></div>
          <div class="stat-key">Años en TIC y startups</div>
        </div>
        <div class="reveal reveal-delay-2">
          <div class="stat-val">UY</div>
          <div class="stat-key">Ecosistema Emprendedor</div>
        </div>
        <div class="reveal reveal-delay-3">
          <div class="stat-val">∞</div>
          <div class="stat-key">Disponibilidad de consultoría</div>
        </div>
      </div>
    </div>

    <div class="hero-vis reveal">
      <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <style>
            @keyframes orbit { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
            @keyframes pulse { 0%, 100% { r: 3px; opacity: 0.8; } 50% { r: 5px; opacity: 0.3; } }
            .orbit-ring { animation: orbit 20s linear infinite; transform-origin: 200px 200px; }
            .pulse-node { animation: pulse 2s ease-in-out infinite; }
          </style>
        </defs>
        <circle cx="200" cy="200" r="150" fill="none" stroke="var(--cyan)" stroke-width="1" opacity="0.15"/>
        <circle cx="200" cy="200" r="100" fill="none" stroke="var(--border-cyan)" stroke-width="1" opacity="0.1"/>
        <g class="orbit-ring">
          <circle cx="350" cy="200" r="4" fill="var(--cyan)" opacity="0.7"/>
          <circle cx="200" cy="50" r="4" fill="var(--amber)" opacity="0.7"/>
          <circle cx="50" cy="200" r="4" fill="var(--emerald)" opacity="0.7"/>
        </g>
        <circle cx="200" cy="200" r="6" fill="var(--cyan)"/>
        <circle cx="200" cy="200" r="10" fill="none" stroke="var(--cyan)" stroke-width="1" opacity="0.5"/>
        <circle cx="200" cy="200" r="15" fill="none" stroke="var(--cyan)" stroke-width="1" opacity="0.3"/>
        <circle cx="280" cy="160" r="3" fill="var(--text)" opacity="0.6" class="pulse-node"/>
        <circle cx="320" cy="240" r="3" fill="var(--text)" opacity="0.6" class="pulse-node"/>
        <circle cx="150" cy="120" r="3" fill="var(--text)" opacity="0.6" class="pulse-node"/>
        <circle cx="250" cy="280" r="3" fill="var(--text)" opacity="0.6" class="pulse-node"/>
        <circle cx="100" cy="260" r="3" fill="var(--text)" opacity="0.6" class="pulse-node"/>
        <line x1="200" y1="200" x2="280" y2="160" stroke="var(--border-cyan)" stroke-width="0.5" opacity="0.3"/>
        <line x1="200" y1="200" x2="320" y2="240" stroke="var(--border-cyan)" stroke-width="0.5" opacity="0.3"/>
        <line x1="200" y1="200" x2="150" y2="120" stroke="var(--border-cyan)" stroke-width="0.5" opacity="0.3"/>
        <line x1="200" y1="200" x2="250" y2="280" stroke="var(--border-cyan)" stroke-width="0.5" opacity="0.3"/>
        <line x1="200" y1="200" x2="100" y2="260" stroke="var(--border-cyan)" stroke-width="0.5" opacity="0.3"/>
      </svg>
    </div>
  </div>
</section>

<!-- ═══ GLOSARIO STARTUPS ═════════════════════════════════════════════ -->
<section class="glossary-preview">
  <div class="glossary-preview-inner">
    <div class="section-eyebrow">Ecosistema TIC Uruguay</div>
    <h2 class="glossary-preview-heading">Glosario Startups</h2>
    <p class="glossary-preview-desc">
      Términos clave del ecosistema emprendedor tecnológico de Uruguay: financiamiento, marco legal,
      infraestructura, talento y estrategia operacional para tu startup.
    </p>
    <div class="glossary-preview-grid">
      {%- for term in collections.glossary | limit(3) %}
      <a href="/glossary/{{ term.data.slug }}" class="glossary-card reveal reveal-delay-{{ loop.index }}">
        <div class="glossary-card-cat">{{ term.data.category }}</div>
        <div class="glossary-card-term">{{ term.data.term }}</div>
        <p class="glossary-card-def">{{ term.data.metaDescription }}</p>
      </a>
      {%- endfor %}
    </div>
    <div style="margin-top: 3rem; text-align: center;">
      <a href="/glossary" class="btn-ghost">Ver todos los términos →</a>
    </div>
  </div>
</section>

<!-- ═══ SERVICIOS ══════════════════════════════════════════════════════ -->
<section id="servicios" class="services-section">
  <div class="services-inner">
    <div class="section-eyebrow">Especialización</div>
    <h2 class="services-heading">Servicios para Startups</h2>
    <div class="services-grid">

      <div class="svc-card c1 reveal reveal-delay-1">
        <div class="svc-num">// 01</div>
        <svg class="svc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path>
          <polyline points="13 2 13 9 20 9"></polyline>
        </svg>
        <h3 class="svc-title">Asesoría TIC para Startups</h3>
        <p class="svc-desc">
          Guía especializada en selección de tecnologías, arquitectura de sistemas iniciales,
          escalabilidad y decisiones TIC que alinean con el crecimiento de tu startup.
        </p>
      </div>

      <div class="svc-card c2 reveal reveal-delay-2">
        <div class="svc-num">// 02</div>
        <svg class="svc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="16" rx="2"></rect>
          <path d="M9 9h6M9 15h6"></path>
        </svg>
        <h3 class="svc-title">Infraestructura Digital Inicial</h3>
        <p class="svc-desc">
          Setup de infraestructura optimizada: hosting, dominios, seguridad básica,
          backup y continuidad operativa diseñados para etapa MVP y growth inicial.
        </p>
      </div>

      <div class="svc-card c3 reveal reveal-delay-3">
        <div class="svc-num">// 03</div>
        <svg class="svc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 11l3 3L22 4"></path>
          <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
        </svg>
        <h3 class="svc-title">Compliance &amp; Normativa Uruguay</h3>
        <p class="svc-desc">
          Orientación en requisitos legales y técnicos de Uruguay: regulación TIC,
          protección de datos, SAS, Zonas Francas y oportunidades de financiamiento.
        </p>
      </div>

    </div>
  </div>
</section>

<!-- ═══ SOBRE MÍ ══════════════════════════════════════════════════════ -->
<section id="sobre" class="about-section">
  <div class="about-inner">
    <div>
      <div class="section-eyebrow">Perfil Profesional</div>
      <h2 class="about-heading">Sobre mí</h2>
      <p class="reveal reveal-delay-1" style="color: var(--text); line-height: 1.8; margin-bottom: 1.5rem;">
        Consultor TIC especializado en el ecosistema emprendedor de Uruguay con más de 10 años de experiencia
        asesorando fundadores en la navegación del marco legal, financiamiento, infraestructura digital y decisiones tecnológicas clave.
      </p>
      <p class="reveal reveal-delay-2" style="color: var(--text); line-height: 1.8; margin-bottom: 1.5rem;">
        Trabajo con startups en etapa seed, MVP y growth para diseñar arquitecturas escalables, optimizar costos TIC,
        acceder a fondos ANDE/ANNI, cumplir normativa SAS/LSRL y posicionar sus operaciones en el ecosistema regional
        (Mercosur y acceso a mercados internacionales).
      </p>
      <p class="reveal reveal-delay-3" style="color: var(--text); line-height: 1.8;">
        Mi enfoque combina conocimiento técnico riguroso con mentoría estratégica de negocio,
        ayudando a fundadores a tomar decisiones TIC que escalen con su startup sin distraerse
        de la tracción comercial.
      </p>
    </div>
    <div class="stats-stack">
      <div class="stat-card c1 reveal reveal-delay-1">
        <div class="stat-card-value">10+</div>
        <div class="stat-card-label">Años en TIC y startups</div>
      </div>
      <div class="stat-card c2 reveal reveal-delay-2">
        <div class="stat-card-value">UY</div>
        <div class="stat-card-label">Ecosistema · ANDE · ANNI</div>
      </div>
      <div class="stat-card c3 reveal reveal-delay-3">
        <div class="stat-card-value">∞</div>
        <div class="stat-card-label">Disponibilidad de consultoría</div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ CONTACTO ══════════════════════════════════════════════════════ -->
<section id="contacto" class="contact-section">
  <div class="contact-inner">
    <div class="section-eyebrow">Disponibilidad</div>
    <h2 class="contact-heading">Contacto</h2>
    <p class="contact-sub">
      Disponible para asesoría especializada en TIC, estrategia de startup,
      y navegación del ecosistema emprendedor de Uruguay.
    </p>
    <div class="contact-links">
      <a href="https://www.linkedin.com/in/antonio-galgano-votta-713b523a7/"
