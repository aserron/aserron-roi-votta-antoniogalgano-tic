# Enable Gzip Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Cache Control
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Remove .html extension
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Remove trailing slash (optional)
    # RewriteCond %{REQUEST_FILENAME} !-d
    # RewriteRule ^(.+)/$ /$1 [R=301,L]

    # Clean URLs: serve /path as /path.html (no trailing slash)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.+?)/?$ /$1.html [L]

    # 404 handling
    ErrorDocument 404 /404.html
</IfModule>

# ═══════════════════════════════════════════════════════════
# SECURITY HEADERS
# ═══════════════════════════════════════════════════════════
<IfModule mod_headers.c>
    # Prevent MIME-type sniffing (XSS protection)
    Header set X-Content-Type-Options "nosniff"

    # Clickjacking protection: only allow framing from same origin
    Header set X-Frame-Options "SAMEORIGIN"

    # XSS Protection (legacy, but still recommended)
    Header set X-XSS-Protection "1; mode=block"

    # Referrer Policy: only send origin when cross-origin
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Content Security Policy: strict policy for static site
    # - Only allow content from same origin
    # - Block inline scripts (nonce-based allowed via script tags)
    # - Prevent form submissions to external origins
    # - Allow Google Fonts (temporary) + self-hosted fonts
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self'; frame-ancestors 'self';"

    # HTTP Strict Transport Security (HSTS)
    # Force HTTPS for 1 year, include subdomains
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Permissions Policy: disable potentially sensitive APIs
    # (modern standard, replaces deprecated Feature-Policy)
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=()"
</IfModule>

# ═══════════════════════════════════════════════════════════
# ACCESS CONTROL
# ═══════════════════════════════════════════════════════════

# Disable directory indexing (prevent listing directory contents)
Options -Indexes

# Block access to sensitive files
<FilesMatch "^\.(env|git|htaccess|htpasswd|svn)$|^\.git|^\.svn">
    Order allow,deny
    Deny from all
</FilesMatch>

# Allow access to .well-known files for security discovery
<DirectoryMatch "\.well-known">
    Order allow,deny
    Allow from all
</DirectoryMatch>

# ═══════════════════════════════════════════════════════════
# ADDITIONAL SECURITY MEASURES
# ═══════════════════════════════════════════════════════════

# Disable PHP execution in certain directories (if applicable)
<FilesMatch "\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Prevent access to backups and source files
<FilesMatch "\.(bak|config|sql|fla|psd|ini|log|sh|inc|swp|dist)$">
    Order allow,deny
    Deny from all
</FilesMatch>
