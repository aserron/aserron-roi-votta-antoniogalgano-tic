{
  "env": { "node": true, "es2022": true },
  "parserOptions": { "ecmaVersion": 2022 },
  "extends": ["eslint:recommended"],
  "rules": {
    "no-console": "off",
    "no-unused-vars": "warn",
    "prefer-const": "error",
    "eqeqeq": "error"
  },
  "ignorePatterns": ["node_modules/", "public_html/", "src/glossary/"]
}
